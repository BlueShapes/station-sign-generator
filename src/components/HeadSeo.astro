---
interface Props {
  title: string;
  description: string;
  locale: string;
  ogImageUrl: string;
  canonical: string;
  locales: string[];
}

const { title, description, locale, ogImageUrl, canonical, locales } = Astro.props;
---
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content={title} />
{locales.map((l) => (
  <link rel="alternate" hreflang={l} href={`${canonical.replace(`/${locale}/`, `/${l}/`)}`} />
))}
<link rel="alternate" hreflang="x-default" href={canonical.replace(`/${locale}/`, '/en/')} />
<link rel="icon" href="/favicon.ico" />
