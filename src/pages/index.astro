---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeadSeo from "../components/HeadSeo.astro";
import StationSignApp from "../components/StationSignApp";
import { loadTranslations } from "../i18n/translations";

const lang = "ja";
const allMessages = {
  ja: loadTranslations("ja"),
  en: loadTranslations("en"),
};
const messages = allMessages[lang];

const siteOrigin =
  import.meta.env.SITE ?? "https://stationsigngen.aosankaku.net";
const title =
  (messages as Record<string, Record<string, string>>)?.meta?.title ??
  "駅名標ジェネレーター";
const description =
  (messages as Record<string, Record<string, string>>)?.meta?.description ?? "";
const ogImagePath =
  (messages as Record<string, string>)?.["$og-image-path"] ??
  "/images/ja/ogp.png";
const ogImageUrl = `${siteOrigin}${ogImagePath}`;
const canonical = `${siteOrigin}/`;

const alternates = [
  { lang: "ja", href: `${siteOrigin}/` },
  { lang: "en", href: `${siteOrigin}/en/` },
  { lang: "x-default", href: `${siteOrigin}/` },
];
---

<BaseLayout title={title} description={description} locale={lang}>
  <Fragment slot="head">
    <HeadSeo
      title={title}
      description={description}
      locale={lang}
      ogImageUrl={ogImageUrl}
      canonical={canonical}
      alternates={alternates}
    />
  </Fragment>
  <StationSignApp client:only="react" locale={lang} allMessages={allMessages} />
</BaseLayout>
